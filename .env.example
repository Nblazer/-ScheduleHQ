# PostgreSQL connection string (Neon: dashboard → Connection Details)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Any long random string (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
SESSION_SECRET="replace-me-with-32-bytes-of-random"

# Public URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------------
# Email — pick ONE option. If neither is set, emails log to the server
# console instead of being sent (fine for dev).
# ------------------------------------------------------------------

# Option A (FREE, no domain needed) — Gmail SMTP.
#   1. Turn on 2-Step Verification on the Gmail account.
#   2. Google Account → Security → App passwords → generate one for "Mail".
#   3. Paste the 16-char password below (no spaces).
GMAIL_USER=""                # your.name@gmail.com
GMAIL_APP_PASSWORD=""        # 16-character app password from Google

# Option B — Resend. Requires verifying a domain you own at resend.com/domains.
RESEND_API_KEY=""

# Display name + address on outgoing email. With Gmail SMTP, the email portion
# gets rewritten to your Gmail address; only the display name is honored.
EMAIL_FROM="ScheduleHQ <noreply@yourdomain.com>"
