// ScheduleHQ schema
// Multi-tenant by Organization. Role hierarchy: OWNER > ADMIN > MANAGER > EMPLOYEE.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ReportStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum ReportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Organization {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  // Theme overrides (optional org-wide default). Keys: preset, accent, radius.
  themePreset     String         @default("midnight")
  themeAccent     String         @default("indigo")
  // Optional business logo as a base64 data URL ("data:image/png;base64,...").
  // Capped at ~256KB at the application layer to keep the DB lean.
  logoDataUrl     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  users           User[]
  memberships     Membership[]
  invites         Invite[]
  shifts          Shift[]
  dayNotes        DayNote[]
  announcements   Announcement[]
  reports         Report[]
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  name                String
  passwordHash        String
  // DEPRECATED — kept for migration safety. Authoritative data is in Membership.
  // New code reads membership.role / membership.active instead.
  role                Role           @default(EMPLOYEE)
  active              Boolean        @default(true)
  emailVerifiedAt     DateTime?
  // Per-user theme override (falls back to org default if null)
  themePreset         String?
  themeAccent         String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // DEPRECATED — kept for migration safety so `prisma db push` doesn't drop data.
  // Authoritative org assignments live in Membership.
  organizationId      String
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  memberships         Membership[]
  sessions            Session[]
  verifications       EmailVerification[]
  shifts              Shift[]        @relation("ShiftEmployee")
  shiftsCreated       Shift[]        @relation("ShiftCreator")
  dayNotesCreated     DayNote[]
  announcementsPosted Announcement[]
  reportsSubmitted    Report[]       @relation("ReportSubmitter")
  reportsAssigned     Report[]       @relation("ReportAssignee")

  @@index([organizationId])
}

// A user's membership in one organization. Users can be in many orgs.
// Role and active status are per-membership — being Manager at Dunkin
// doesn't make you Manager at the pizza shop.
model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Session {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token                String   @unique
  expiresAt            DateTime
  // Which org this session is currently viewing. Switchable at runtime.
  // Nullable so pre-existing sessions from before multi-org migration still work.
  activeOrganizationId String?
  createdAt            DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
}

model Invite {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email           String
  name            String
  role            Role
  token           String       @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime     @default(now())

  @@index([organizationId])
  @@index([email])
}

model Shift {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        User         @relation("ShiftEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User         @relation("ShiftCreator", fields: [createdById], references: [id])
  startsAt        DateTime
  endsAt          DateTime
  position        String?
  notes           String?
  // If set, this shift is one instance of a recurring series. All instances
  // of the same recurrence share the same seriesId, which lets us scope
  // deletes to "just this one", "this and future", or "entire series".
  seriesId        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, startsAt])
  @@index([employeeId, startsAt])
  @@index([seriesId])
}

// A note attached to a calendar day (e.g. "milk machine cleaning day").
model DayNote {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Stored as UTC midnight of the target day (YYYY-MM-DD @ 00:00:00Z).
  date            DateTime
  title           String
  body            String?
  color           String       @default("blue")
  createdById     String
  createdBy       User         @relation(fields: [createdById], references: [id])
  // Recurring series id — see Shift.seriesId for rationale.
  seriesId        String?
  createdAt       DateTime     @default(now())

  @@index([organizationId, date])
  @@index([seriesId])
}

model Announcement {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title           String
  body            String
  pinned          Boolean      @default(false)
  postedById      String
  postedBy        User         @relation(fields: [postedById], references: [id])
  createdAt       DateTime     @default(now())

  @@index([organizationId, createdAt])
}

model Report {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submitterId     String
  submitter       User           @relation("ReportSubmitter", fields: [submitterId], references: [id])
  assigneeId      String?
  assignee        User?          @relation("ReportAssignee", fields: [assigneeId], references: [id])
  subject         String
  body            String
  priority        ReportPriority @default(NORMAL)
  status          ReportStatus   @default(OPEN)
  managerResponse String?
  respondedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId, status])
  @@index([submitterId])
}
