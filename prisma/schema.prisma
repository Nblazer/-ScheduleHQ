// ScheduleHQ schema
// Multi-tenant by Organization. Role hierarchy: OWNER > ADMIN > MANAGER > EMPLOYEE.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ReportStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum ReportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SwapStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum Plan {
  FREE
  BASIC
  PRO
}

enum ReminderRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Organization {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  // Theme overrides (optional org-wide default). Keys: preset, accent, radius.
  themePreset     String         @default("midnight")
  themeAccent     String         @default("indigo")
  // Optional business logo as a base64 data URL ("data:image/png;base64,...").
  // Capped at ~256KB at the application layer to keep the DB lean.
  logoDataUrl     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  users           User[]
  memberships     Membership[]
  invites         Invite[]
  shifts          Shift[]
  dayNotes        DayNote[]
  announcements   Announcement[]
  reports         Report[]
  resourcePages   ResourcePage[]
  swapRequests    ShiftSwapRequest[]
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  name                String
  passwordHash        String
  // DEPRECATED — kept for migration safety. Authoritative data is in Membership.
  // New code reads membership.role / membership.active instead.
  role                Role           @default(EMPLOYEE)
  active              Boolean        @default(true)
  emailVerifiedAt     DateTime?
  // Per-user theme override (falls back to org default if null)
  themePreset         String?
  themeAccent         String?
  // Optional contact + payout info shared across all their workspaces.
  phone               String?
  // Free-form payment profile string (e.g. "@venmo-handle", "paypal.me/x",
  // "Cash App: $User"). Surfaced to managers when paying out timesheets.
  paymentProfile      String?
  // Pricing plan. Drives workspace + member-count limits app-wide.
  plan                Plan           @default(FREE)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // DEPRECATED — kept for migration safety so `prisma db push` doesn't drop data.
  // Authoritative org assignments live in Membership.
  organizationId      String
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  memberships         Membership[]
  sessions            Session[]
  verifications       EmailVerification[]
  passwordResets      PasswordReset[]
  shifts              Shift[]        @relation("ShiftEmployee")
  shiftsCreated       Shift[]        @relation("ShiftCreator")
  dayNotesCreated     DayNote[]
  announcementsPosted Announcement[]
  reportsSubmitted    Report[]       @relation("ReportSubmitter")
  reportsAssigned     Report[]       @relation("ReportAssignee")
  resourcePagesCreated ResourcePage[]
  swapsRequested      ShiftSwapRequest[] @relation("SwapRequester")
  swapsReceived       ShiftSwapRequest[] @relation("SwapTarget")
  reminders           PersonalReminder[]

  @@index([organizationId])
}

// A user's membership in one organization. Users can be in many orgs.
// Role and active status are per-membership — being Manager at Dunkin
// doesn't make you Manager at the pizza shop.
model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role
  active         Boolean      @default(true)
  // Hourly pay rate in cents (e.g. 1500 = $15/hr). Null = not set.
  // Privacy: only the member themselves and managers+ of the org see this.
  hourlyRateCents Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Session {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token                String   @unique
  expiresAt            DateTime
  // Which org this session is currently viewing. Switchable at runtime.
  // Nullable so pre-existing sessions from before multi-org migration still work.
  activeOrganizationId String?
  createdAt            DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
}

// One-time tokens emailed to a user when they click "Forgot password" on
// the login page. Short TTL (1h), single-use, all sessions for the user
// are killed when the reset is consumed so an attacker can't ride along.
model PasswordReset {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Invite {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email           String
  name            String
  role            Role
  token           String       @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime     @default(now())

  @@index([organizationId])
  @@index([email])
}

model Shift {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        User         @relation("ShiftEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User         @relation("ShiftCreator", fields: [createdById], references: [id])
  startsAt        DateTime
  endsAt          DateTime
  position        String?
  notes           String?
  // If set, this shift is one instance of a recurring series. All instances
  // of the same recurrence share the same seriesId, which lets us scope
  // deletes to "just this one", "this and future", or "entire series".
  seriesId        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  swapRequestsForRequester ShiftSwapRequest[] @relation("SwapRequesterShift")
  swapRequestsForTarget    ShiftSwapRequest[] @relation("SwapTargetShift")

  @@index([organizationId, startsAt])
  @@index([employeeId, startsAt])
  @@index([seriesId])
}

// A note attached to a calendar day (e.g. "milk machine cleaning day").
model DayNote {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Stored as UTC midnight of the target day (YYYY-MM-DD @ 00:00:00Z).
  date            DateTime
  title           String
  body            String?
  color           String       @default("blue")
  createdById     String
  createdBy       User         @relation(fields: [createdById], references: [id])
  // Recurring series id — see Shift.seriesId for rationale.
  seriesId        String?
  createdAt       DateTime     @default(now())

  @@index([organizationId, date])
  @@index([seriesId])
}

model Announcement {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title           String
  body            String
  pinned          Boolean      @default(false)
  postedById      String
  postedBy        User         @relation(fields: [postedById], references: [id])
  createdAt       DateTime     @default(now())

  @@index([organizationId, createdAt])
}

// A request from one employee to swap a shift (or give it away). Another
// employee can accept or decline. On accept, we atomically transfer the
// shift(s) between employees and mark the request ACCEPTED.
model ShiftSwapRequest {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  requesterId        String
  requester          User         @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterShiftId   String
  requesterShift     Shift        @relation("SwapRequesterShift", fields: [requesterShiftId], references: [id], onDelete: Cascade)

  targetUserId       String
  targetUser         User         @relation("SwapTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  // If null, the requester is giving their shift away and just wants the
  // target to take it on. If set, they want to swap for this specific shift.
  targetShiftId      String?
  targetShift        Shift?       @relation("SwapTargetShift", fields: [targetShiftId], references: [id], onDelete: SetNull)

  note               String?
  status             SwapStatus   @default(PENDING)
  createdAt          DateTime     @default(now())
  resolvedAt         DateTime?

  @@index([organizationId, status])
  @@index([targetUserId, status])
  @@index([requesterId])
}

// A personal reminder, tied to the User (not a workspace). Travels with them
// across every business they're in. Supports recurrence and a notify-before
// window that drives the in-app notification bell.
model PersonalReminder {
  id                  String             @id @default(cuid())
  userId              String
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title               String
  body                String?
  // One of: indigo, violet, emerald, amber, rose, sky (matches the accent palette).
  color               String             @default("indigo")
  // First occurrence (for non-recurring this is THE occurrence).
  scheduledAt         DateTime
  recurrence          ReminderRecurrence @default(NONE)
  // Optional end date for recurrence; null = forever.
  recurrenceUntil     DateTime?
  // Minutes before the scheduled time when the bell should fire.
  // 0 = at scheduled time. Common: 0, 5, 15, 60, 1440 (1 day), 10080 (1 week).
  notifyBeforeMinutes Int                @default(0)
  // Tracks the most recent occurrence the user dismissed from the bell.
  // Used to skip already-acknowledged occurrences for recurring reminders.
  lastDismissedAt     DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([userId, scheduledAt])
}

// A free-form content page (training videos, handbooks, recipes, links, etc.).
// Managers can create/edit; everyone in the org can view. Body is plain text
// with URL + YouTube-link auto-detection at render time — no rich-text editor.
model ResourcePage {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title           String
  icon            String?      // An emoji or short glyph shown on the card/tab
  body            String       @default("")
  sortOrder       Int          @default(0)
  createdById     String
  createdBy       User         @relation(fields: [createdById], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, sortOrder])
}

model Report {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submitterId     String
  submitter       User           @relation("ReportSubmitter", fields: [submitterId], references: [id])
  assigneeId      String?
  assignee        User?          @relation("ReportAssignee", fields: [assigneeId], references: [id])
  subject         String
  body            String
  priority        ReportPriority @default(NORMAL)
  status          ReportStatus   @default(OPEN)
  managerResponse String?
  respondedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId, status])
  @@index([submitterId])
}
